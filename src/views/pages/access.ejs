<%- include("../layouts/base", {
  title,
  appTitle,
  currentUserEmail: null,
  currentUserHref: "/access",
  pageTitle: "Welcome",
  pageMeta: "Sign in to the RideMatrix platform.",
  showContextBar: false,
  activeRoleLabel: "",
  hintsLabel: "",
  showRoleSwitch: false,
  showExitLink: false,
  body: `
    <section class="panel panel--compact panel--access-intro">
      <h1>Welcome to ${appTitle}</h1>
      <p>
        Sign in using the email address linked to your RideMatrix account.
        A sign-in link will be sent to your inbox — no password required.
      </p>
      <p>
        If you need access or require help, please contact your administrator
        or Technical Support.
      </p>
    </section>

    <section class="panel panel--compact">
      <h2>Sign in</h2>
      <form method="post" action="/access">
        <label for="email">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
        <button type="submit">Continue</button>
      </form>
    </section>
  `
}) %>